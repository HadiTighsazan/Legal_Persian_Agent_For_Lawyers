# Frontend Development Environment
# NOTE: In Docker, the backend is at localhost:8000 directly (not through nginx).
# The Django backend does NOT have an /api prefix — that's only added by nginx.
# So the correct URL is http://localhost:8000 (without /api).
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=DocuChat
VITE_APP_DESCRIPTION=AI Document Assistant
