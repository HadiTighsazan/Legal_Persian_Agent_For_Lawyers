# ============================================
# DocuChat - Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values
# ============================================

# ============================================
# Database Configuration (PostgreSQL with pgvector)
# ============================================

# PostgreSQL Database Credentials
POSTGRES_DB=docuchat_db
POSTGRES_USER=docuchat_user
POSTGRES_PASSWORD=changeme_secure_password

# Database Connection URL (used by Django)
DATABASE_URL=postgresql://docuchat_user:changeme_secure_password@postgres:5432/docuchat_db

# ============================================
# Redis Configuration (Cache & Celery Broker)
# ============================================

# Redis Connection URL
REDIS_URL=redis://redis:6379/0

# ============================================
# Django Configuration
# ============================================

# Django Security - Generate a secure random key
DJANGO_SECRET_KEY=changeme_generate_a_secure_random_key

# Debug Mode (True for development, False for production)
DJANGO_DEBUG=True

# Allowed Hosts (comma-separated list)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# CORS Allowed Origins (comma-separated list)
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Security Settings (Production: set to True)
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False

# ============================================
# JWT Authentication Configuration
# ============================================

# JWT Secret Key (required) - used for signing tokens
# Generate with: openssl rand -base64 32
JWT_SECRET=changeme_generate_a_secure_jwt_secret

# JWT Access Token Expiry (optional, default: 15min)
# Access token expiration in minutes
JWT_ACCESS_TOKEN_EXPIRY=15

# JWT Refresh Token Expiry (optional, default: 7d)
# Refresh token expiration in days
JWT_REFRESH_TOKEN_EXPIRY=7

# ============================================
# OpenAI API Configuration (Production)
# ============================================

# OpenAI API Key (required for embeddings and chat when EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=sk-...your_openai_api_key_here...

# OpenAI Model Configuration
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4-turbo-preview

# Chat Max Tokens (max tokens per response, applies to all providers)
CHAT_MAX_TOKENS=1000

# RAG Configuration
RAG_MAX_HISTORY_TURNS=10
RAG_CONTEXT_TOKEN_BUDGET=4000

# ============================================
# Google Gemini API Configuration
# ============================================

# Google Gemini API Key (required for embeddings when EMBEDDING_PROVIDER=google)
GOOGLE_API_KEY=AIzaSyAUpCi6VZUFgvftRCVI-nq2k_i6gRbsLTU

# Gemini Embedding Model
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Gemini Chat Model
GEMINI_CHAT_MODEL=gemini-2.0-flash

# Embedding Provider (google for Gemini, openai for OpenAI, ollama for Ollama)
EMBEDDING_PROVIDER=google

# Chat Provider (openai for OpenAI, google for Gemini, ollama for Ollama)
CHAT_PROVIDER=openai

# OpenAI Embedding Model (used when EMBEDDING_PROVIDER=openai)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================
# Ollama Configuration (Development Embeddings)
# ============================================

# Ollama Base URL (used when EMBEDDING_PROVIDER=ollama)
# In Docker: http://host.docker.internal:11434 (reaches host's Ollama)
# On host: http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama Embedding Model
OLLAMA_EMBEDDING_MODEL=bge-m3

# Ollama Chat Model (used when CHAT_PROVIDER=ollama)
OLLAMA_CHAT_MODEL=llama3

# ============================================
# OpenRouter Configuration (Embeddings via API)
# ============================================

# OpenRouter API Key (used when EMBEDDING_PROVIDER=openrouter)
# Get your key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# OpenRouter Base URL
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenRouter Embedding Model
OPENROUTER_EMBEDDING_MODEL=bge-m3

# ============================================
# Frontend Configuration (Vite/React)
# ============================================

# Backend API URL for frontend
VITE_API_BASE_URL=http://localhost/api

# Application Metadata
VITE_APP_NAME=DocuChat
VITE_APP_DESCRIPTION=AI Document Assistant

# ============================================
# Storage Configuration
# ============================================

# Storage backend type (local or s3)
STORAGE_TYPE=local

# Local storage path for uploaded documents
LOCAL_STORAGE_PATH=./media/documents

# S3 bucket configuration (used when STORAGE_TYPE=s3)
S3_BUCKET_NAME=docuchat-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ============================================
# File Upload Configuration
# ============================================

# Maximum upload size in bytes (50MB)
MAX_UPLOAD_SIZE=52428800

# Allowed file types (comma-separated MIME types)
ALLOWED_FILE_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain

# ============================================
# Celery Configuration (Background Tasks)
# ============================================

# Celery Broker (Redis)
CELERY_BROKER_URL=redis://redis:6379/0

# Celery Result Backend (Redis)
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Celery Task Settings
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=1800  # 30 minutes in seconds

# ============================================
# Logging Configuration
# ============================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log Format (verbose, simple, json)
LOG_FORMAT=verbose

# ============================================
# Email Configuration (Optional - for production)
# ============================================

# Uncomment and configure for production email
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password
# DEFAULT_FROM_EMAIL=noreply@docuchat.example.com

# ============================================
# Application-Specific Configuration
# ============================================

# Embedding Dimension (Gemini text-embedding-004)
EMBEDDING_DIMENSION=1024

# pgvector ivfflat index probe count (1-100, higher = better recall but slower)
VECTOR_SEARCH_PROBES=10

# Chunk Size for Document Processing (in characters)
DOCUMENT_CHUNK_SIZE=1000

# Chunk Overlap for Document Processing (in characters)
DOCUMENT_CHUNK_OVERLAP=200

# Persian Legal Text Processing
PERSIAN_NORMALIZATION_ENABLED=True
LEGAL_CHUNKING_ENABLED=True
LEGAL_MAX_CHUNK_SIZE=2000
LEGAL_CHUNK_OVERLAP_CLAUSES=1

# Extraction Strategy
EXTRACTION_BACKEND=pymupdf
EXTRACTION_AUTO_FALLBACK=True
EXTRACTION_GARBLED_THRESHOLD=0.3

# ============================================
# Instructions for Generating Secrets
# ============================================

# 1. Generate Django Secret Key:
#    python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

# 2. Get OpenAI API Key:
#    Visit https://platform.openai.com/api-keys

# 3. Generate Secure Passwords:
#    Use a password manager or: openssl rand -base64 32

# 4. Generate Database Password:
#    openssl rand -base64 24

# ============================================
# Development vs Production Notes
# ============================================

# For Development:
# - DJANGO_DEBUG=True
# - Use localhost in ALLOWED_HOSTS
# - Disable SSL settings (SECURE_SSL_REDIRECT=False, etc.)
# - Use default Redis and PostgreSQL passwords

# For Production:
# - DJANGO_DEBUG=False
# - Set proper ALLOWED_HOSTS (your domain)
# - Enable SSL settings (SECURE_SSL_REDIRECT=True, etc.)
# - Use real email configuration
# - Use strong, unique passwords for all services
# - Consider using Docker secrets or Kubernetes secrets
# - Set CELERY_TASK_TIME_LIMIT appropriately for your workload
# - Configure proper logging (LOG_LEVEL=WARNING or ERROR)

# ============================================
# Service Health Check Configuration
# ============================================

# Health check timeout (seconds)
HEALTH_CHECK_TIMEOUT=30

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# ============================================
# Rate Limiting Configuration
# ============================================

# API Rate Limit (requests per minute per user)
API_RATE_LIMIT=60

# File Upload Rate Limit (requests per minute per user)
UPLOAD_RATE_LIMIT=10
